# Frontend env vars (Vite — VITE_ prefix only).
# Copy to .env and fill in. .env is gitignored.

# Supabase project URL (e.g. https://zwtsofwlomiwqtpxdppy.supabase.co).
VITE_SUPABASE_URL=

# Supabase anon (publishable) key. Safe to ship to the browser — RLS is
# the gate. NEVER paste the service-role key here.
VITE_SUPABASE_ANON_KEY=

# Backend API base URL. Local dev default; override for staging/prod.
VITE_API_BASE_URL=http://localhost:8000/api/v1
