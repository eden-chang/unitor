# Copy to .env (gitignored) and fill in for local development.

# === Application ===
APP_ENV=dev                 # dev | staging | prod
APP_PORT=8000
LOG_LEVEL=INFO

# === Postgres (Supabase) ===
# Runtime: Supavisor transaction-mode pooler (port 6543). Used by FastAPI.
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Migrations: direct connection (port 5432). Used by Alembic only.
DATABASE_DIRECT_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# === Supabase Auth / API ===
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# During rotation only; remove 24h after rotation completes.
SUPABASE_JWT_SECRET_PREVIOUS=

# === Cron auth ===
# Shared secret sent by pg_cron / GitHub Actions in X-Cron-Token header.
CRON_TOKEN=

# === Cloudflare R2 ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PROFILES=unitor-profiles-dev
R2_BUCKET_ROSTERS=unitor-rosters-dev
R2_BUCKET_ARCHIVES=unitor-archives-dev
R2_PUBLIC_BASE_URL=https://cdn.example.dev

# === Email (Resend) ===
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@unitor.app

# === Observability ===
SENTRY_DSN=

# === CORS ===
# Comma-separated list of allowed origins (no trailing slash).
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://*.vercel.app
